############################################################## Extra scripts
init script:
	# Load scripts for image box
	include file: /magic-default-image.mse-include/scripts
	include file: /magic-all-style.mse-include/script
	
	# Should hybrids have a grey name?
	mask_hybrid_with_land := { styling.grey_hybrid_name }
	
	#Should multicolor lands with basic land types have a colored name?
	mask_multi_land_with_color := { styling.colored_multicolor_land_name }

	template_prefix := [
	card: "normal/"
	level1: "level/"
	level2: "level/"
	crown:"crown/"
	aliascrown:"alias/"
	innercrown:"innercrown/"
	circle:"circle/"
	pt: "pt/" 
	stamp: "stamp/" 
	identity: "/magic-identity-new.mse-include/"
	]

	template_suffix := [
	card: "card.png"
	level1: "1.png"
	level2: "2.png"
	crown:"crown.png" 
	aliascrown:"aliascrown.png"
	innercrown:"crown.png"
	circle:".png"
	pt: ".png"
	stamp: "stamp.png" 
	identity: "identity.png"
	]

	crown_follow := {
		if input == "crown" or input == "aliascrown" then if is_legend() then "l" else ""
		else ""
	}
	innercrown_follow := {
		if input != "innercrown" then ""
		else if styling.inner_crown_style == "companion"
			then "com"
		else if styling.inner_crown_style == "nyx" or ( is_nyx() )
			then "nyx"
		else ""
	}


	
	template      := { template_prefix[type] + input + crown_follow(type) + innercrown_follow(type) + template_suffix[type] }
	land_template := { template_prefix[type] + (if input == "a" then "c" else input) + crown_follow(type) + innercrown_follow(type) + template_suffix[type] }
	#(if landless(type) then "" else "l")

	# Use land templates for previews because they show more contrast
	hybrid_previews := "land,hybrid"

	crown_background := { color_background(type:"crown",     base_hybrid:card_hybrid) }
	innercrown_background := { color_background(type:"innercrown",     base_hybrid:card_hybrid) }
	aliascrown_background := { color_background(type:"aliascrown",     base_hybrid:card_hybrid) }
	level1_background := { color_background(type:"level1",     base_hybrid:card_hybrid) }
	level2_background := { color_background(type:"level2",     base_hybrid:card_hybrid) }
	circle_background := { color_background(type:"circle",     base_hybrid:card_hybrid) }

	# Use the normal tap symbol
	mana_t := {
		if      styling.tap_symbol == "old"        then "old"
		else if styling.tap_symbol == "diagonal T" then "older"
		else                                            "new"
	}
	
	# Use guild mana symbols?
	guild_mana := { styling.use_guild_mana_symbols }
	
	# Is the card a promo card?
	card_shape := {"normal"}

	is_promo := { styling.promo }
	is_legend := {set.auto_legends and (contains(card.super_type, match:"Legendary") or contains(card.super_type, match:"传奇") or contains(card.type, match:"Mewk")) }
	is_nyx := { chosen(styling.frames, choice:"nyx") and (contains(card.super_type, match:"Enchantment") or contains(card.super_type, match:"结界")) }

	is_serialized := { chosen(styling.frames, choice:"serialized") }
	use_phyrexian_font := { chosen(styling.frames, choice:"use phyrexian font") }
	use_acorn_stamp := { styling.use_acorn_stamp }

	has_alias := { styling.use_alias }
	mana_sort := {
		if styling.unsorted_casting_cost then
			input
		else
			sort_text@(order: "XYZI[0123456789]HSCA(WUBRG)")()
	}
	ancestral_mana := { styling.ancestral_mana_symbols }
	has_identity := { styling.color_indicator_dot }
	is_unsorted := {styling.remove_from_autocount}

	use_main_rarity := { contains(set.mainframe_rarity_name, match: ".png")}
	un_png := replace@(match:".png", replace: "")

	#############################################################################################################
	nametype_font_choose :={
		if styling.nametype_font != "" then styling.nametype_font else 
		if use_phyrexian_font() then "Phi_horizontal_gbrsh_3.0"
		else if set.card_language == "日本語" then "MotoyaF4Aporo W5 KP"
		else if set.card_language != "简体中文" then "Beleren Bold"
		else "华康魏碑 Std W7" 
	}

	nametop_shift := {
		if set.card_language == "日本語" then 56
		else if set.card_language != "简体中文" then 59
		else 57 + (if use_phyrexian_font() then shrink_name()/2 else 0)
		+
		if styling.name_top_shift != "" then to_number(styling.name_top_shift) else 0
	}

	typetop_shift := {
		shrink_type()/2 + 598 
		+
		if styling.type_top_shift != "" then to_number(styling.type_top_shift) else 0
	}
	###################################################################################################################

	two_boxes := {styling.station_textboxes == "one" }
	three_boxes := {styling.station_textboxes == "two" }

	lv_1_height := { split_12() - textbox_top() }
	lv_2_height := { (if two_boxes() then textbox_bottom_fix() else split_23()) - split_12() }
	lv_3_height := { textbox_bottom() - (if two_boxes() then textbox_bottom_fix() else split_23()) }

	l1_center := {textbox_top() + 0.5*lv_1_height()}
	l2_center := {textbox_top() + lv_1_height() + 0.5*lv_2_height()}
	l3_center := {textbox_top() + lv_1_height() + lv_2_height() + 0.5*lv_3_height()}

	textbox_top:={ 658 + chop_top() }
	textbox_bottom:={ 968 - chop_bot() }
	textbox_bottom_fix:={ 968 }
	split_12:={ (if three_boxes() then 761 else 813) + to_number( pull_comma_array(styling.level_offset, cell:0, end:true) ) }
	split_23:={ (if three_boxes() then 864 else textbox_bottom()) + to_number( pull_comma_array(styling.level_offset, cell:1, end:true) ) }

	special_text := { 
			card.level_1_text + (if card.pt != "" then " [" + card.pt + "]" else "") + "\n"
			+ (if card.level_1 != "" then "[" + card.level_1 + "] " else "") + card.level_2_text + (if card.pt_2 != "" then " [" + card.pt_2 + "]" else "") + (if card.level_3_text != "" then "\n" else "")
			+ (if card.level_2 != "" then "[" + card.level_2 + "] " else "") + card.level_3_text + (if card.pt_3 != "" then " [" + card.pt_3 + "]" else "")


			#(if card.level_0 != "" then "[" + level_label(0) + " " + card.level_0 + "] " else "") + 
			#(if card.level_4_text != "" then "\n" else "")
			#+ (if card.level_3 != "" then "[" + level_label(3) + " " + card.level_3 + "] " else "") + card.level_4_text + (if card.pt_7 != "" then " [" + card.pt_7 + "]" else "")
	}

############################################################## Set info fields
